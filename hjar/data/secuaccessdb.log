/*C3*/SET SCHEMA PUBLIC
CREATE TABLE IF NOT EXISTS "users" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "email" VARCHAR(4000) NOT NULL UNIQUE,\u000a  "password" VARCHAR(4000) NOT NULL,\u000a  "firstName" VARCHAR(4000) NOT NULL,\u000a  "lastName" VARCHAR(4000) NOT NULL,\u000a  "phone" VARCHAR(4000),\u000a  "status" VARCHAR(4000) DEFAULT 'active',\u000a  "lastLoginAt" TIMESTAMP,\u000a  "createdAt" TIMESTAMP,\u000a  "updatedAt" TIMESTAMP\u000a)
CREATE INDEX IF NOT EXISTS "idx_users_0" ON "users" ("status" ASC)
CREATE TABLE IF NOT EXISTS "roles" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "name" VARCHAR(4000) NOT NULL UNIQUE,\u000a  "description" VARCHAR(4000),\u000a  "createdAt" TIMESTAMP,\u000a  "updatedAt" TIMESTAMP\u000a)
CREATE TABLE IF NOT EXISTS "permissions" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "name" VARCHAR(4000) NOT NULL UNIQUE,\u000a  "description" VARCHAR(4000),\u000a  "category" VARCHAR(4000),\u000a  "createdAt" TIMESTAMP,\u000a  "updatedAt" TIMESTAMP\u000a)
CREATE TABLE IF NOT EXISTS "permission_categories" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "name" VARCHAR(4000) NOT NULL UNIQUE,\u000a  "label" VARCHAR(4000) NOT NULL,\u000a  "description" VARCHAR(4000),\u000a  "icon" VARCHAR(4000),\u000a  "order" DOUBLE DEFAULT 0,\u000a  "system" BOOLEAN,\u000a  "createdAt" TIMESTAMP,\u000a  "updatedAt" TIMESTAMP\u000a)
CREATE INDEX IF NOT EXISTS "idx_permission_categories_0" ON "permission_categories" ("order" ASC, "name" ASC)
CREATE TABLE IF NOT EXISTS "settings" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "key" VARCHAR(4000) NOT NULL UNIQUE,\u000a  "value" CLOB NOT NULL,\u000a  "createdAt" TIMESTAMP,\u000a  "updatedAt" TIMESTAMP\u000a)
CREATE TABLE IF NOT EXISTS "auditlogs" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "userName" VARCHAR(4000) NOT NULL,\u000a  "userRole" VARCHAR(4000) NOT NULL,\u000a  "action" VARCHAR(4000) NOT NULL,\u000a  "module" VARCHAR(4000) NOT NULL,\u000a  "resource" VARCHAR(4000) DEFAULT '',\u000a  "resourceId" VARCHAR(4000) DEFAULT '',\u000a  "details" CLOB,\u000a  "ipAddress" VARCHAR(4000) DEFAULT '',\u000a  "status" VARCHAR(4000) DEFAULT 'success',\u000a  "timestamp" TIMESTAMP,\u000a  "userId" VARCHAR(36) NOT NULL\u000a)
CREATE INDEX IF NOT EXISTS "idx_auditlogs_0" ON "auditlogs" ("timestamp" DESC)
CREATE INDEX IF NOT EXISTS "idx_auditlogs_1" ON "auditlogs" ("module" ASC, "timestamp" DESC)
CREATE INDEX IF NOT EXISTS "idx_auditlogs_2" ON "auditlogs" ("userId" ASC, "timestamp" DESC)
CREATE TABLE IF NOT EXISTS "clients" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "clientNumber" VARCHAR(4000) UNIQUE,\u000a  "clientType" VARCHAR(4000) NOT NULL,\u000a  "firstName" VARCHAR(4000) NOT NULL,\u000a  "lastName" VARCHAR(4000) NOT NULL,\u000a  "phone" VARCHAR(4000),\u000a  "email" VARCHAR(4000),\u000a  "dateOfBirth" TIMESTAMP,\u000a  "gender" VARCHAR(4000),\u000a  "photo" VARCHAR(4000),\u000a  "faceDescriptor" CLOB,\u000a  "address" VARCHAR(4000),\u000a  "wilaya" VARCHAR(4000),\u000a  "qrCode" VARCHAR(4000) UNIQUE,\u000a  "status" VARCHAR(4000) DEFAULT 'active',\u000a  "notes" VARCHAR(4000),\u000a  "rfidTagId" VARCHAR(36),\u000a  "createdBy" VARCHAR(36) NOT NULL,\u000a  "createdAt" TIMESTAMP,\u000a  "updatedAt" TIMESTAMP\u000a)
CREATE INDEX IF NOT EXISTS "idx_clients_0" ON "clients" ("phone" ASC)
CREATE INDEX IF NOT EXISTS "idx_clients_1" ON "clients" ("status" ASC)
CREATE INDEX IF NOT EXISTS "idx_clients_2" ON "clients" ("clientType" ASC)
CREATE TABLE IF NOT EXISTS "activities" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "name" VARCHAR(4000) NOT NULL,\u000a  "slug" VARCHAR(4000) NOT NULL UNIQUE,\u000a  "description" VARCHAR(4000),\u000a  "icon" VARCHAR(4000),\u000a  "color" VARCHAR(4000),\u000a  "capacity" DOUBLE,\u000a  "currentOccupancy" DOUBLE DEFAULT 0,\u000a  "schedule" CLOB,\u000a  "ticketValidityMode" VARCHAR(4000) DEFAULT 'single_use',\u000a  "ticketDuration" DOUBLE,\u000a  "price" DOUBLE DEFAULT 0 NOT NULL,\u000a  "currency" VARCHAR(4000) DEFAULT 'DA',\u000a  "status" VARCHAR(4000) DEFAULT 'active',\u000a  "sortOrder" DOUBLE DEFAULT 0,\u000a  "createdBy" VARCHAR(36),\u000a  "createdAt" TIMESTAMP,\u000a  "updatedAt" TIMESTAMP\u000a)
CREATE INDEX IF NOT EXISTS "idx_activities_0" ON "activities" ("status" ASC)
CREATE TABLE IF NOT EXISTS "subscription_plans" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "name" VARCHAR(4000) NOT NULL,\u000a  "description" VARCHAR(4000),\u000a  "type" VARCHAR(4000) NOT NULL,\u000a  "duration" DOUBLE,\u000a  "activities" CLOB,\u000a  "price" DOUBLE NOT NULL,\u000a  "currency" VARCHAR(4000) DEFAULT 'DA',\u000a  "isActive" BOOLEAN,\u000a  "createdAt" TIMESTAMP,\u000a  "updatedAt" TIMESTAMP\u000a)
CREATE INDEX IF NOT EXISTS "idx_subscription_plans_0" ON "subscription_plans" ("isActive" ASC)
CREATE TABLE IF NOT EXISTS "client_accesses" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "accessType" VARCHAR(4000) NOT NULL,\u000a  "totalQuota" DOUBLE,\u000a  "remainingQuota" DOUBLE,\u000a  "startDate" TIMESTAMP NOT NULL,\u000a  "endDate" TIMESTAMP,\u000a  "status" VARCHAR(4000) DEFAULT 'active',\u000a  "client" VARCHAR(36) NOT NULL,\u000a  "plan" VARCHAR(36),\u000a  "activity" VARCHAR(36) NOT NULL,\u000a  "createdBy" VARCHAR(36) NOT NULL,\u000a  "createdAt" TIMESTAMP,\u000a  "updatedAt" TIMESTAMP\u000a)
CREATE INDEX IF NOT EXISTS "idx_client_accesses_0" ON "client_accesses" ("client" ASC, "activity" ASC)
CREATE INDEX IF NOT EXISTS "idx_client_accesses_1" ON "client_accesses" ("client" ASC, "status" ASC)
CREATE INDEX IF NOT EXISTS "idx_client_accesses_2" ON "client_accesses" ("status" ASC)
CREATE TABLE IF NOT EXISTS "tickets" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "ticketNumber" VARCHAR(4000) UNIQUE,\u000a  "ticketType" VARCHAR(4000) DEFAULT 'standard',\u000a  "code" VARCHAR(4000) UNIQUE,\u000a  "codeFormat" VARCHAR(4000) DEFAULT 'qrcode',\u000a  "clientName" VARCHAR(4000) NOT NULL,\u000a  "activityName" VARCHAR(4000) NOT NULL,\u000a  "validityMode" VARCHAR(4000) NOT NULL,\u000a  "validUntil" TIMESTAMP,\u000a  "status" VARCHAR(4000) DEFAULT 'active',\u000a  "scannedAt" TIMESTAMP,\u000a  "amount" DOUBLE DEFAULT 0 NOT NULL,\u000a  "currency" VARCHAR(4000) DEFAULT 'DA',\u000a  "printCount" DOUBLE DEFAULT 0,\u000a  "client" VARCHAR(36) NOT NULL,\u000a  "clientAccess" VARCHAR(36) NOT NULL,\u000a  "activity" VARCHAR(36) NOT NULL,\u000a  "sourceClient" VARCHAR(36),\u000a  "scannedBy" VARCHAR(36),\u000a  "createdBy" VARCHAR(36) NOT NULL,\u000a  "createdAt" TIMESTAMP,\u000a  "updatedAt" TIMESTAMP\u000a)
CREATE INDEX IF NOT EXISTS "idx_tickets_0" ON "tickets" ("client" ASC)
CREATE INDEX IF NOT EXISTS "idx_tickets_1" ON "tickets" ("status" ASC)
CREATE INDEX IF NOT EXISTS "idx_tickets_2" ON "tickets" ("validUntil" ASC)
CREATE INDEX IF NOT EXISTS "idx_tickets_3" ON "tickets" ("codeFormat" ASC)
CREATE TABLE IF NOT EXISTS "scan_logs" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "scanMethod" VARCHAR(4000) DEFAULT 'webcam',\u000a  "result" VARCHAR(4000) NOT NULL,\u000a  "denyReason" VARCHAR(4000),\u000a  "quotaBefore" DOUBLE,\u000a  "quotaAfter" DOUBLE,\u000a  "isReentry" BOOLEAN,\u000a  "timestamp" TIMESTAMP,\u000a  "ticket" VARCHAR(36),\u000a  "client" VARCHAR(36),\u000a  "activity" VARCHAR(36),\u000a  "scannedBy" VARCHAR(36) NOT NULL\u000a)
CREATE INDEX IF NOT EXISTS "idx_scan_logs_0" ON "scan_logs" ("client" ASC)
CREATE INDEX IF NOT EXISTS "idx_scan_logs_1" ON "scan_logs" ("timestamp" DESC)
CREATE INDEX IF NOT EXISTS "idx_scan_logs_2" ON "scan_logs" ("result" ASC)
CREATE TABLE IF NOT EXISTS "lockers" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "number" DOUBLE NOT NULL UNIQUE,\u000a  "zone" VARCHAR(4000) NOT NULL,\u000a  "status" VARCHAR(4000) DEFAULT 'available',\u000a  "rfidLockId" VARCHAR(4000),\u000a  "lastAssignedAt" TIMESTAMP,\u000a  "currentClient" VARCHAR(36),\u000a  "currentTag" VARCHAR(36),\u000a  "createdAt" TIMESTAMP,\u000a  "updatedAt" TIMESTAMP\u000a)
CREATE INDEX IF NOT EXISTS "idx_lockers_0" ON "lockers" ("zone" ASC)
CREATE INDEX IF NOT EXISTS "idx_lockers_1" ON "lockers" ("status" ASC)
CREATE TABLE IF NOT EXISTS "rfid_tags" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "tagId" VARCHAR(4000) NOT NULL UNIQUE,\u000a  "status" VARCHAR(4000) DEFAULT 'available',\u000a  "assignedAt" TIMESTAMP,\u000a  "deactivatedAt" TIMESTAMP,\u000a  "notes" VARCHAR(4000),\u000a  "client" VARCHAR(36),\u000a  "assignedBy" VARCHAR(36),\u000a  "createdAt" TIMESTAMP,\u000a  "updatedAt" TIMESTAMP\u000a)
CREATE INDEX IF NOT EXISTS "idx_rfid_tags_0" ON "rfid_tags" ("status" ASC)
CREATE INDEX IF NOT EXISTS "idx_rfid_tags_1" ON "rfid_tags" ("client" ASC)
CREATE TABLE IF NOT EXISTS "locker_events" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "eventType" VARCHAR(4000) NOT NULL,\u000a  "notes" VARCHAR(4000),\u000a  "timestamp" TIMESTAMP,\u000a  "locker" VARCHAR(36) NOT NULL,\u000a  "client" VARCHAR(36),\u000a  "rfidTag" VARCHAR(36),\u000a  "performedBy" VARCHAR(36) NOT NULL\u000a)
CREATE INDEX IF NOT EXISTS "idx_locker_events_0" ON "locker_events" ("locker" ASC)
CREATE INDEX IF NOT EXISTS "idx_locker_events_1" ON "locker_events" ("timestamp" DESC)
CREATE TABLE IF NOT EXISTS "ticket_counters" (\u000a  "id" VARCHAR(36) PRIMARY KEY,\u000a  "name" VARCHAR(4000) NOT NULL UNIQUE,\u000a  "seq" DOUBLE DEFAULT 0\u000a)
CREATE TABLE IF NOT EXISTS "user_roles" (\u000a  "userId" VARCHAR(36) NOT NULL,\u000a  "roleId" VARCHAR(36) NOT NULL,\u000a  PRIMARY KEY ("userId", "roleId")\u000a)
CREATE TABLE IF NOT EXISTS "role_permissions" (\u000a  "roleId" VARCHAR(36) NOT NULL,\u000a  "permissionId" VARCHAR(36) NOT NULL,\u000a  PRIMARY KEY ("roleId", "permissionId")\u000a)
DISCONNECT
