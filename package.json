{
  "name": "@mostajs/orm",
  "version": "2.4.0",
  "description": "Hibernate-inspired multi-dialect ORM for Node.js/TypeScript — One API, 13 databases, zero lock-in, runs in the browser/WebContainer via WASM",
  "author": "Dr Hamid MADANI <drmdh@msn.com>",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js",
      "default": "./dist/register.js"
    },
    "./bridge": {
      "types": "./dist/bridge/index.d.ts",
      "import": "./dist/bridge/index.js",
      "default": "./dist/bridge/index.js"
    },
    "./validator": {
      "types": "./dist/validator/index.d.ts",
      "import": "./dist/validator/index.js",
      "default": "./dist/validator/index.js"
    }
  },
  "bin": {
    "mostajs-orm-validator": "dist/validator/cli.js"
  },
  "files": [
    "dist",
    "bridge/MostaJdbcBridge.java",
    "wire.json",
    "LICENSE",
    "README.md",
    "llms.txt",
    "CHANGELOG.md"
  ],
  "keywords": [
    "orm",
    "database",
    "mongodb",
    "sqlite",
    "postgresql",
    "mysql",
    "mariadb",
    "oracle",
    "mssql",
    "cockroachdb",
    "db2",
    "hana",
    "spanner",
    "sybase",
    "hibernate",
    "repository-pattern",
    "multi-dialect",
    "typescript",
    "sql.js",
    "wasm",
    "webcontainer",
    "browser",
    "edge"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/apolocine/mosta-orm"
  },
  "homepage": "https://mostajs.dev",
  "bugs": {
    "url": "https://github.com/apolocine/mosta-orm/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mostajs/config": "^1.0.0",
    "jiti": "^2.7.0",
    "ts-morph": "^28.0.0"
  },
  "peerDependencies": {
    "@google-cloud/spanner": ">=7.0.0",
    "@mostajs/socle": ">=2.0.0",
    "@sap/hana-client": ">=2.0.0",
    "better-sqlite3": ">=9.0.0",
    "mongoose": ">=7.0.0",
    "mysql2": ">=3.0.0",
    "sql.js": ">=1.8.0"
  },
  "peerDependenciesMeta": {
    "mongoose": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "mariadb": {
      "optional": true
    },
    "oracledb": {
      "optional": true
    },
    "mssql": {
      "optional": true
    },
    "ibm_db": {
      "optional": true
    },
    "@sap/hana-client": {
      "optional": true
    },
    "@google-cloud/spanner": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mostajs/socle": "^2.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "better-sqlite3": "^12.6.2",
    "mongoose": "^8.0.0",
    "sql.js": "^1.14.1",
    "typescript": "^5.6.0"
  },
  "optionalDependencies": {
    "ibm_db": "^4.0.0",
    "mariadb": "^3.5.2",
    "mssql": "^12.2.1",
    "oracledb": "^6.10.0",
    "pg": "^8.20.0"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/apolocine"
  }
}
